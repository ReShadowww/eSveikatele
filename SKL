            let mtl = document.getElementById('mtl').value.replace(".", ",") || "xx"
            let dtl = document.getElementById('dtl').value.replace(".", ",") || "xx"
            let nedtl = document.getElementById('nedtl').value.replace(".", ",") || "xx"
            let creatinine = document.getElementById('creatinine').value.replace(".", ",") || "xx"
            let gfg = document.getElementById('gfg').value.replace(".", ",") || "xx"
            let heartRate = document.getElementById('heart-rate').value || "xx"
            let ksh = document.querySelector('input[name="ksh"]:checked') ? document.querySelector('input[name="ksh"]:checked').value : '?'
            let metabolicSyndromeCriteria = document.getElementById('metabolic-syndrome-criteria').value || "?"
            let metabolicSyndrome = document.querySelector('input[name="metabolic-syndrome"]:checked') ? document.querySelector('input[name="metabolic-syndrome"]:checked').value : '?'
            let familialDyslipidemia = document.querySelector('input[name="familial-dyslipidemia"]:checked') ? document.querySelector('input[name="familial-dyslipidemia"]:checked').value : '?'
            let score2 = document.getElementById('score2').value || "xx"
            let cvdRiskGroup = document.querySelector('input[name="cvd-risk-group"]:checked') ? document.querySelector('input[name="cvd-risk-group"]:checked').value : '?'
            let aksSistolinis = document.getElementById('aks-sistolinis').value || "xxx"
            let aksDiastolinis = document.getElementById('aks-diastolinis').value || "xx"
            let weight = document.getElementById('weight').value.replace(".", ",") || "xx"
            let height = document.getElementById('height').value.replace(".", ",") || "xx"
            let waist = document.getElementById('waist').value.replace(".", ",") || "xx"
            let kmi = document.getElementById('kmi').value.replace(".", ",") || "xx"
            let smokingStatus = document.querySelector('input[name="smoking-status"]:checked') ? document.querySelector('input[name="smoking-status"]:checked').value : '?'
            let alcoholUse = document.querySelector('input[name="alcohol-use"]:checked') ? document.querySelector('input[name="alcohol-use"]:checked').value : '?'

            if (ksh === "ne") { ksh = "KSH požymių nėra" }
            if (ksh === "taip") { ksh = "yra KSH požymių" }

            if (metabolicSyndrome === "nėra") { metabolicSyndrome = " Metabolinio sindromo nėra." }
            if (metabolicSyndrome === "yra") { metabolicSyndrome = " Yra metabolinis sindromas." }

            let summary1 = `Vertinama pagal ŠKL prevencijos programą. Lėtinės ligos: ${chronicDisease}. Vartojami vaistai: ${medications}.\n1 - Vertinami kraujo tyr. (aptarti): Glikemija — ${glucose} mmol/l, lipidograma: B. chol — ${totalCholesterol} mmol/l, MTL — ${mtl} mmol/l, DTL — ${dtl} mmol/l, neDTL — ${nedtl} mmol/l. Kreatininas — ${creatinine} µmol/l, GFG — ${gfg} ml/min/1,73m\u00B2.\nEKG — SR, ŠSD — ${heartRate} k/min, ${ksh}.\n2 - Metabolinio sindromo kriterijai: ${metabolicSyndromeCriteria}/5.${metabolicSyndrome}\n3 - Vertinama šeiminės dislipidemijos tikimybė, pagal modifikuotus šeiminės dislipidemijos tikimybės diagnostikos kriterijus: ${familialDyslipidemia}.\n4 - Vertinama SCORE2 — SCORE2 skalė: ${score2} %.\n5 - Nustatoma širdies ir kraujagyslių ligų rizikos grupė — ${cvdRiskGroup}.`


            let summary2 = `Širdies tonai ritmiški, AKS ${aksSistolinis}/${aksDiastolinis} mmHg, ŠSD ${heartRate} k/min.\nPlaučiuose alsavimas be karkalų. KD — 18. Cianozės nestebima.\nPilvas minkštas, neskausmingas. Oda ir gleivinės be pakitimų. Kojose edemų nestebima. Pėdų būklė gera.\nSvoris — ${weight} kg;\nŪgis — ${height} cm;\nLiemens apimtis — ${waist} cm;\nKMI — ${kmi} kg/m\u00B2.`


            let siektinasMTL = 'xx'
            if (cvdRiskGroup === "maža ir vidutinė") { siektinasMTL = "<2,6 mmol/l" }
            if (cvdRiskGroup === "didelė") { siektinasMTL = "<1,8 mmol/l" }
            if (cvdRiskGroup === "labai didelė") { siektinasMTL = "<1,4 mmol/l" }

            let kmiRekomendacija = ''
            if (parseFloat(kmi.replace(",", ".")) >= 25) {
                kmiRekomendacija = "Norint pasiekti KMI būtina didinti fizinį aktyvumą ir mažinti suvartojamų kalorijų kiekį."
            }

            let rukymoRekomendacija = '?'
            if (smokingStatus === "rūko") { rukymoRekomendacija = 'rūko. Nurodytos pagalbos priemonės mesti rūkyti. Metimas rūkyti: informuota dėl žalingo rūkymo poveikio, informuota apie pagalbos priemones.' }
            if (smokingStatus === "nerūko") { rukymoRekomendacija = 'nerūko. Vengti pasyvaus rūkymo.' }

            let alkoholioRekomendacija = '?'
            if (alcoholUse === "nustatytas") { alkoholioRekomendacija = 'rizikingas vartojimas nustatytas. Nurodytos pagalbos priemonės rizikai sumažinti.' }
            if (alcoholUse === "nenustatytas") { alkoholioRekomendacija = 'rizikingas vartojimas nenustatytas.' }

            let summary3 = `Tyrimų ir gydymo planas:\nSekti AKS ir ŠSD, vengti rizikos veiksnių.\n1) Siektinas AKS mažiau 130/80 mmHg.\n2) Siektinas MTL — ${siektinasMTL}. Šiuo metu MTL — ${mtl} mmol/l.\n3) Aptariama dieta ir jos laikymosi galimybės: Dieta: vaisių ir daržovių suvartojimas >200 g per dieną, 35-45 g skaidulų (rekomenduojama iš kruopų), saikingas riešutų suvartojimas (30 g per dieną, nesūdytų), 1-2 porcijos žuvies per savaitę (viena riebi žuvis), ribotas liesos mėsos, neriebių pieno produktų ir skystų augalinių aliejų kiekis, sotieji riebalai <10 % visų suvartojamų riebalų, juos keisti polinesočiausiais riebalais, mažinti transriebalų kiekį, pageidautina, kad jie nebūtų iš perdirbto maisto ir sudarytų <1 % visos suvartojamos energijos, druskos <5-6 g per dieną. Atsisakyti alkoholio, jei vartojamas, riboti suvartojimą iki <100 g per savaitę arba <15 g per dieną. Vengti daug energijos turinčių maisto produktų, tokių kaip cukrumi saldinti gaivieji gėrimai.\n4) Fizinio aktyvumo didinimas: 30-60 minučių vidutinio sunkumo fizinis aktyvumas kasdien, naudinga ir nereguliari fizinė veikla.\n5) Siektinas kūno masės indeksas (KMI) <25, šiuo metu KMI — ${kmi} kg/m\u00B2. ${kmiRekomendacija}\n6) Tabako vartojimo įvertinimas: ${rukymoRekomendacija}\n7) Rizikingo alkoholio vartojimo įvertinimas: ${alkoholioRekomendacija}`

            let rekomendacijos = 'Rekomendacijos: ?'
            if (cvdRiskGroup === "maža ir vidutinė") { rekomendacijos = "1) Nustatyta ŠKL rizika — maža / vidutinė.\n2) Kitas patikrinimas pagal ŠKL programą po 4 metų." }
            if (cvdRiskGroup === "didelė") { rekomendacijos = "1) Nustatyta ŠKL rizika — didelė.\n2) Rekonsultacija ŠMK po 6 mėn. gyvensenos pokyčiams ir gydymo rezultatams įvertinti.\n3) Kitas patikrinimas pagal ŠKL programą po 2 metų." }
            if (cvdRiskGroup === "labai didelė") { rekomendacijos = "1) Nustatyta ŠKL rizika — labai didelė.\n2) Rekonsultacija ŠMK po 6 mėn. gyvensenos pokyčiams ir gydymo rezultatams įvertinti.\n3) Kitas patikrinimas pagal ŠKL programą po 1 metų.\n4) Siuntimas gyd. kardiologui — prašau konsultuoti dėl tolimesnio ištyrimo ir gydymo pagal ŠKL programą nustačius labai didelę riziką." }

            let summary4 = `Rekomendacijos:\n${rekomendacijos}`

            let summary = summary1 + "\n\n\n" + summary2 + "\n\n\n" + summary3 + "\n\n\n" + summary4
            document.getElementById('summary').value = summary
        }

        function updateOnInput() {
            metabolinioSindromoKriterijaiCalculate()
            seimineDislipidemijaCalculate()
            kmiCalculate()
            score2Calculate()
            riskGroupCalculate()
            fillSummary()
        }

    </script>
</head>
<style>
    #chronic-diseases,
    #medications {
        width: 100%;
        height: 5em;
        box-sizing: border-box;
    }

    #summary {
        width: 100%;
        height: 50em;
        box-sizing: border-box;
    }
</style>

<body>
    <form id="myForm">

        <fieldset>
            <legend><b>Demografiniai rodikliai:</b></legend>
            <div>
                <!-- Lytis -->
                <label for="sex">Paciento lytis:</label><br>
                <input type="radio" id="sex-male" name="sex" value="vyras" oninput="updateOnInput()">
                <label for="sex-male">Vyras</label><br>
                <input type="radio" id="sex-female" name="sex" value="moteris" oninput="updateOnInput()">
                <label for="sex-female">Moteris</label><br><br>
            </div>
            <div>
                <!-- Amžius -->
                <label for="age">Paciento amžius:</label><br>
                <input type="number" min="40" , step="1" id="age" name="age" oninput="updateOnInput()">
            </div>
        </fieldset><br>

        <fieldset>
            <legend><b>Žalingi įpročiai</b></legend>
            <div>
                <!-- Rūkymas -->
                <label for="smoking-status">Tabako vartojimo įvertinimas:</label><br>
                <input type="radio" id="smoking-status-smokes" name="smoking-status" value="rūko"
                    oninput="updateOnInput()">
                <label for="smoking-status-smokes">Rūko</label><br>
                <input type="radio" id="smoking-status-non-smoker" name="smoking-status" value="nerūko"
                    oninput="updateOnInput()">
                <label for="smoking-status-non-smoker">Nerūko</label><br><br>
            </div>
            <div>
                <!-- Alkoholis -->
                <label for="alcohol-use">Rizikingo alkoholio vartojimo įvertinimas:</label><br>
                <input type="radio" id="alcohol-use-yes" name="alcohol-use" value="nustatytas"
                    oninput="updateOnInput()">
                <label for="alcohol-use-yes">Nustatytas</label><br>
                <input type="radio" id="alcohol-use-no" name="alcohol-use" value="nenustatytas"
                    oninput="updateOnInput()">
                <label for="alcohol-use-no">Nenustatytas</label>
            </div>
        </fieldset><br>

        <!-- Lėtinės ligos -->
        <label for="chronic-diseases">Lėtinės ligos:</label><br>
        <textarea id="chronic-diseases" name="chronic-diseases" placeholder="Lėtinės ligos..."
            oninput="updateOnInput()"></textarea><br><br>

        <!-- Vartojami vaistai-->
        <label for="medications">Vartojami vaistai:</label><br>
        <textarea id="medications" name="medications" placeholder="Vartojami vaistai..."
            oninput="updateOnInput()"></textarea><br><br>

        <fieldset>
            <legend><b>Pagrindinių vaistų anamnezė:</b></legend>
            <div>
                <!-- Lipidus mažinantys vaistai -->
                <label for="lipidu-vaistai">Pacientas vartoja lipidus mažinančius vaistus?</label><br>
                <input type="radio" id="lipidu-vaistai-taip" name="lipidu-vaistai" value="taip"
                    oninput="updateOnInput()">
                <label for="lipidu-vaistai-taip">Taip</label><br>
                <input type="radio" id="lipidu-vaistai-ne" name="lipidu-vaistai" value="ne" oninput="updateOnInput()">
                <label for="lipidu-vaistai-ne">Ne</label><br><br>
            </div>
            <div>
                <!-- AH vaistai / AH -->
                <label for="ah-vaistai">Pacientas, kuriam nustatyta AH, vartoja antihipertenzinius vaistus?</label><br>
                <input type="radio" id="ah-vaistai-taip" name="ah-vaistai" value="taip" oninput="updateOnInput()">
                <label for="ah-vaistai-taip">Taip</label><br>
                <input type="radio" id="ah-vaistai-ne" name="ah-vaistai" value="ne" oninput="updateOnInput()">
                <label for="ah-vaistai-ne">Ne</label><br><br>
            </div>
            <div>
                <!-- Glikemijos vaistai -->
                <label for="glikemijos-vaistai">Pacientas vartoja glikemiją mažinančius vaistus?</label><br>
                <input type="radio" id="glikemijos-vaistai-taip" name="glikemijos-vaistai" value="taip"
                    oninput="updateOnInput()">
                <label for="glikemijos-vaistai-taip">Taip</label><br>
                <input type="radio" id="glikemijos-vaistai-ne" name="glikemijos-vaistai" value="ne"
                    oninput="updateOnInput()">
                <label for="glikemijos-vaistai-ne">Ne</label>
            </div>
        </fieldset><br>

        <fieldset>
            <legend><b>Laboratoriniai tyrimai:</b></legend>
            <div>
                <!-- Glikemija -->
                <label for="glucose">Glikemija (mmol/l):</label><br>
                <input type="number" min="0" step="0.1" id="glucose" name="glucose" oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- Bendras cholesterolis -->
                <label for="total-cholesterol">Bendras cholesterolis (mmol/l):</label><br>
                <input type="number" min="0" step="0.1" id="total-cholesterol" name="total-cholesterol"
                    oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- DTL -->
                <label for="dtl">DTL (mmol/l):</label><br>
                <input type="number" min="0" step="0.1" id="dtl" name="dtl" oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- neDTL -->
                <label for="nedtl">neDTL (mmol/l):</label><br>
                <input type="number" min="0" step="0.1" id="nedtl" name="nedtl" oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- MTL -->
                <label for="mtl">MTL (mmol/l):</label><br>
                <input type="number" min="0" step="0.1" id="mtl" name="mtl" oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- Trigliceridai -->
                <label for="tgl">Trigliceridai (mmol/l):</label><br>
                <input type="number" min="0" step="0.1" id="tgl" name="tgl" oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- Kreatininas -->
                <label for="creatinine">Kreatininas (µmol/l):</label><br>
                <input type="number" min="0" step="0.1" id="creatinine" name="creatinine"
                    oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- GFG -->
                <label for="gfg">aGFG:</label><br>
                <input type="number" min="0" step="0.1" id="gfg" name="gfg" oninput="updateOnInput()">
            </div>
        </fieldset><br>

        <fieldset>
            <legend><b>Širdies rodikliai:</b></legend>
            <div>
                <!-- AKS -->
                <label for="aks-sistolinis">AKS sistolinis / diastolinis (mm/Hg):</label><br>
                <input type="number" min="0" step="1" max="999" id="aks-sistolinis" name="aks-sistolinis"
                    oninput="updateOnInput()">
                <span>/</span>
                <input type="number" min="0" step="1" max="999" id="aks-diastolinis" name="aks-diastolinis"
                    oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- ŠSD -->
                <label for="heart-rate">ŠSD (k/min):</label><br>
                <input type="number" min="0" id="heart-rate" name="heart-rate" oninput="updateOnInput()"><br><br>
            </div>
            <div>
                <!-- KSH požymiai -->
                <label for="ksh">KSH požymiai:</label><br>
                <input type="radio" id="ksh-yes" name="ksh" value="taip" oninput="updateOnInput()">
                <label for="ksh-yes">Taip</label><br>
                <input type="radio" id="ksh-no" name="ksh" value="ne" oninput="updateOnInput()">
                <label for="ksh-no">Ne</label>
            </div>
        </fieldset><br>

        <fieldset>
            <legend><b>Šeiminės dislipidemijos tikimybės diagnostikos kriterijai:</b></legend>

            <div>
                <input type="checkbox" id="didelisMTL" name="didelisMTL" oninput="updateOnInput()" />
                <label for="didelisMTL">MTL ≥ 5 mmol/l (negydant antilipidiniais vaistais)</label>
            </div>

            <div>
                <input type="checkbox" id="kraujagysliuLiga" name="kraujagysliuLiga" disabled="disabled"
                    oninput="updateOnInput()" />
                <label for="kraujagysliuLiga">Diagnozuota ankstyva širdies vainikinių, smegenų ar periferinių arterijų
                    liga (vyrai &lt;55 metų, moterys &lt;60 metų)</label>
            </div>

            <div>
                <input type="checkbox" id="kraujagysliuLigaGiminei" name="kraujagysliuLigaGiminei" disabled="disabled"
                    oninput="updateOnInput()" />
                <label for="kraujagysliuLigaGiminei">Pirmos eilės giminaičiui yra nustatyta ankstyva širdies vainikinių,
                    smegenų ar periferinių arterijų liga (vyrams &lt;55 metų, moterims &lt;60 metų)</label>
            </div>

            <div>
                <input type="checkbox" id="ksantomos" name="ksantomos" disabled="disabled" oninput="updateOnInput()" />
                <label for="ksantomos">pacientui iki 45 metų nustatytos ksantomos, ksanteliazmos odoje ir sausgyslėse
                    arba ragenos lankas</label>
            </div><br>

            <div> <!-- Šeiminės dislipidemijos tikimybė -->
                <label for="familial-dyslipidemia">Šeiminės dislipidemijos tikimybė<i> (apskaičiuota
                        automatiškai)</i>:</label><br>
                <input type="radio" id="familial-dyslipidemia-yes" name="familial-dyslipidemia" value="yra"
                    disabled="disabled">
                <label for="familial-dyslipidemia-yes">Yra</label><br>
                <input type="radio" id="familial-dyslipidemia-no" name="familial-dyslipidemia" value="nėra"
                    disabled="disabled">
                <label for="familial-dyslipidemia-no">Nėra</label>
            </div>
        </fieldset><br>

        <fieldset>
            <legend><b>Matavimai:</b></legend>
            <div>
                <!-- Svoris -->
                <label for="weight">Svoris (kg):</label><br>
                <input type="number" min="0" step="0.1" id="weight" name="weight" oninput="updateOnInput()"><br><br>
            </div>

            <div>
                <!-- Ūgis -->
                <label for="height">Ūgis (cm):</label><br>
                <input type="number" min="0" id="height" name="height" oninput="updateOnInput()"><br><br>
            </div>

            <div>
                <!-- Liemuo -->
                <label for="waist">Liemens apimtis (cm):</label><br>
                <input type="number" min="0" step="0.1" id="waist" name="waist" oninput="updateOnInput()"><br><br>
            </div>

            <div>
                <!-- KMI -->
                <label for="kmi">KMI (kg/m<sup>2</sup>):</label><br>
                <input type="text" id="kmi" name="kmi" placeholder="Nepakanka duomenų" readonly="readonly">
                <span><i>(apskaičiuota automatiškai)</i></span>
            </div>
        </fieldset><br>

        <fieldset>
            <legend><b>Metabolinis sindromas</b></legend>
            <div>
                <!-- Metabolinis sindromo kriterijai -->
                <label for="metabolic-syndrome-criteria">Metabolinio sindromo kriterijai (x iš 5):</label><br>
                <input type="text" placeholder="Nepakanka duomenų" id="metabolic-syndrome-criteria"
                    name="metabolic-syndrome-criteria" readonly="readonly">
                <span><i>(apskaičiuota automatiškai)</i></span>
                <br><br>
            </div>
            <div>
                <!-- Metabolinis sindromas yra/nėra -->
                <label for="metabolic-syndrome">Metabolinis sindromas <i>(apskaičiuota automatiškai)</i>:</label><br>
                <input type="radio" id="metabolic-syndrome-yes" name="metabolic-syndrome" value="yra"
                    disabled="disabled">
                <label for=" metabolic-syndrome-yes">Yra</label><br>
                <input type="radio" id="metabolic-syndrome-no" name="metabolic-syndrome" value="nėra"
                    disabled="disabled">
                <label for=" metabolic-syndrome-no">Nėra</label><br><br>
            </div>
        </fieldset><br>

        <fieldset>
            <legend><b>Apskaičiuota rizika:</b></legend>
            <div>
                <!-- Score2 -->
                <label for="score2">SCORE2 skalė (%):</label><br>
                <input type="text" placeholder="Nepakanka duomenų" id="score2" name="score2" readonly="readonly">
                <span><i>(apskaičiuota automatiškai)</i></span><br><br>
            </div>
            <div>
                <!-- ŠKL rizikos grupė -->
                <label for="cvd-risk-group">ŠKL rzikos grupė: <i>(apskaičiuota automatiškai)</i></label><br>
                <input type="radio" id="cvd-risk-low-medium" name="cvd-risk-group" value="maža ir vidutinė"
                    disabled="disabled">
                <label for="cvd-risk-low-medium">Maža ir vidutinė</label><br>
                <input type="radio" id="cvd-risk-high" name="cvd-risk-group" value="didelė" disabled="disabled">
                <label for="cvd-risk-high">Didelė</label><br>
                <input type="radio" id="cvd-risk-very-high" name="cvd-risk-group" value="labai didelė"
                    disabled="disabled">
                <label for="cvd-risk-very-high">Labai didelė</label>
            </div>
        </fieldset><br>

        <!-- Sugeneruotas tekstas -->
        <br>
        <label for="summary">Sugeneruotas tekstas:</label><br>
        <textarea id="summary" name="summary" readonly></textarea><br><br>
        <button type="button" onclick="copyToClipboard()">Kopijuoti sugeneruotą tekstą</button><br><br>

    </form>
    <button onclick="clearInputField()">Viską išvalyti</button>
    <script>

        function clearInputField() {
            document.getElementById('myForm').reset()
        }

        function disableInputScrolling() {
            document.addEventListener("wheel", function (event) {
                if (document.activeElement.type === "number") {
                    document.activeElement.blur()
                }
            })
        }

        disableInputScrolling()
        clearInputField()
    </script>
</body>

</html>
