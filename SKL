        function metabolinioSindromoKriterijaiCalculate() {
            // Padidėjusi liemens apimtis 
            let sex = document.querySelector('input[name="sex"]:checked') ? document.querySelector('input[name="sex"]:checked').value : ''
            let waist = document.getElementById('waist').value

            // Padidėjusi kraujo serumo trigliceridų koncentracija
            // arba asmuo vartoja lipidus mažinančius vaistus
            let tgl = document.getElementById('tgl').value
            let lipiduVaistai = document.querySelector('input[name="lipidu-vaistai"]:checked') ? document.querySelector('input[name="lipidu-vaistai"]:checked').value : ''

            // Sumažėjusi kraujo serumo DTL cholesterolio koncentracija
            // arba asmuo vartoja lipidus mažinančius vaistus
            let dtl = document.getElementById('dtl').value

            // Padidėjęs AKS
            // arba asmuo, kuriam nustatyta arterinė hipertenzija, vartoja antihipertenzinius vaistus
            let aksSistolinis = document.getElementById('aks-sistolinis').value
            let aksDiastolinis = document.getElementById('aks-diastolinis').value
            let ahVaistai = document.querySelector('input[name="ah-vaistai"]:checked') ? document.querySelector('input[name="ah-vaistai"]:checked').value : ''

            // Padidėjusi alkio glikemija
            // arba asmuo vartoja glikemiją mažinančius vaistus
            let glucose = document.getElementById('glucose').value
            let glikemijosVaistai = document.querySelector('input[name="glikemijos-vaistai"]:checked') ? document.querySelector('input[name="glikemijos-vaistai"]:checked').value : ''

            if (sex && waist && tgl && lipiduVaistai && dtl && aksSistolinis && aksDiastolinis && ahVaistai && glucose && glikemijosVaistai) {
                let metaboliniuKriterijuSkaicius = 0
                // Padidėjusi kraujo serumo trigliceridų koncentracija (arba vaistai)
                if (tgl >= 1.7 || lipiduVaistai === "taip") {
                    metaboliniuKriterijuSkaicius++
                }
                // Padidėjęs AKS (arba vaistai)
                if (aksSistolinis >= 130 || aksDiastolinis >= 85 || ahVaistai === "taip") {
                    metaboliniuKriterijuSkaicius++
                }
                // Padidėjusi alkio glikemija (arba vaistai)
                if (glucose >= 5.6 || glikemijosVaistai === "taip") {
                    metaboliniuKriterijuSkaicius++
                }
                if (sex === "vyras") {
                    // Padidėjusi liemens apimtis Vyrui
                    if (waist >= 102) {
                        metaboliniuKriterijuSkaicius++
                    }
                    // Sumažėjusi kraujo serumo DTL cholesterolio koncentracija Vyrui (arba vaistai)
                    if (dtl < 1 || glikemijosVaistai === "taip") {
                        metaboliniuKriterijuSkaicius++
                    }
                }
                if (sex === "moteris") {
                    // Padidėjusi liemens apimtis Moteriai
                    if (waist >= 88) {
                        metaboliniuKriterijuSkaicius++
                    }
                    // Sumažėjusi kraujo serumo DTL cholesterolio koncentracija Moteriai (arba vaistai)
                    if (dtl < 1.3 || glikemijosVaistai === "taip") {
                        metaboliniuKriterijuSkaicius++
                    }
                }

                if (metaboliniuKriterijuSkaicius >= 3) {
                    document.getElementById("metabolic-syndrome-yes").checked = true
                    document.getElementById("metabolic-syndrome-no").checked = false
                } else {
                    document.getElementById("metabolic-syndrome-yes").checked = false
                    document.getElementById("metabolic-syndrome-no").checked = true
                }

                document.getElementById('metabolic-syndrome-criteria').value = metaboliniuKriterijuSkaicius

                return true
            } else {
                return false
            }
        }

        function seimineDislipidemijaCalculate() {
            let didelisMTL = document.querySelector('input[name="didelisMTL"]')
            let kraujagysliuLiga = document.querySelector('input[name="kraujagysliuLiga"]')
            let kraujagysliuLigaGiminei = document.querySelector('input[name="kraujagysliuLigaGiminei"]')
            let ksantomos = document.querySelector('input[name="ksantomos"]')

            if (didelisMTL.checked === false) {
                kraujagysliuLiga.disabled = true
                kraujagysliuLigaGiminei.disabled = true
                ksantomos.disabled = true

                kraujagysliuLiga.checked = false
                kraujagysliuLigaGiminei.checked = false
                ksantomos.checked = false
            } else {
                kraujagysliuLiga.disabled = false
                kraujagysliuLigaGiminei.disabled = false
                ksantomos.disabled = false
            }


            if (didelisMTL.checked === true && (kraujagysliuLiga.checked === true || kraujagysliuLigaGiminei.checked === true || ksantomos.checked === true)) {
                document.getElementById("familial-dyslipidemia-yes").checked = true
                document.getElementById("familial-dyslipidemia-no").checked = false
            } else {
                document.getElementById("familial-dyslipidemia-yes").checked = false
                document.getElementById("familial-dyslipidemia-no").checked = true
            }
        }

        function kmiCalculate() {
            let weightValue = parseFloat(document.getElementById("weight").value)
            let heightValue = parseFloat(document.getElementById("height").value)
            let kmiElement = document.getElementById("kmi")

            // Check if both values are valid numbers and greater than zero
            if (!isNaN(weightValue) && weightValue > 0 && !isNaN(heightValue) && heightValue > 0) {
                let kmiValue = weightValue / ((heightValue / 100) * (heightValue / 100))
                kmiElement.value = kmiValue.toFixed(1).toString().replace(".", ",")
            } else {
                kmiElement.value = ''
            }
        }

        function score2Calculate() {
            let score2Element = document.getElementById('score2')

            let score2Data = JSON.parse(document.getElementById('my-json-data').textContent)
            let sex = document.querySelector('input[name="sex"]:checked') ? document.querySelector('input[name="sex"]:checked').value : ''
            let smokingStatus = document.querySelector('input[name="smoking-status"]:checked') ? document.querySelector('input[name="smoking-status"]:checked').value : ''
            let age = document.getElementById('age').value
            let aksSistolinis = document.getElementById('aks-sistolinis').value
            let nedtl = document.getElementById('nedtl').value
            let ageGroup = ''
            let aksGroup = ''
            let nedtlGroup = ''

            score2Element.setAttribute('placeholder', 'Nepakanka duomenų')
            score2Element.value = ''

            if (sex && smokingStatus && age && aksSistolinis && nedtl) {
                let goodToGo = true

                if (smokingStatus === "rūko") { smokingStatus = "ruko" }
                if (smokingStatus === "nerūko") { smokingStatus = "neruko" }

                // AGE
                age = parseInt(age, 10)
                if (age >= 65 && age <= 69) { ageGroup = "65_69" }
                if (age >= 60 && age <= 64) { ageGroup = "60_64" }
                if (age >= 55 && age <= 59) { ageGroup = "55_59" }
                if (age >= 50 && age <= 54) { ageGroup = "50_54" }
                if (age >= 45 && age <= 49) { ageGroup = "45_49" }
                if (age >= 40 && age <= 44) { ageGroup = "40_44" }
                // TODO
                if (age < 40 || age > 69) {
                    goodToGo = false
                    score2Element.value = ''
                    score2Element.setAttribute('placeholder', 'Netinkamas amžius')
                }

                // AKS
                aksSistolinis = parseInt(aksSistolinis, 10)
                if (aksSistolinis >= 160 && aksSistolinis <= 179) { aksGroup = "160-179" }
                if (aksSistolinis >= 140 && aksSistolinis <= 159) { aksGroup = "140-159" }
                if (aksSistolinis >= 120 && aksSistolinis <= 139) { aksGroup = "120-139" }
                if (aksSistolinis >= 100 && aksSistolinis <= 119) { aksGroup = "100-119" }
                // TODO
                if (aksSistolinis < 100 || aksSistolinis > 179) {
                    goodToGo = false
                    score2Element.value = ''
                    score2Element.setAttribute('placeholder', 'Netinkamas AKS')

                }

                // neDTL
                nedtl = parseFloat(nedtl.replace(",", "."))
                if (nedtl >= 6.0 && nedtl <= 6.9) { nedtlGroup = "6.0-6.9" }
                if (nedtl >= 5.0 && nedtl <= 5.9) { nedtlGroup = "5.0-5.9" }
                if (nedtl >= 4.0 && nedtl <= 4.9) { nedtlGroup = "4.0-4.9" }
                if (nedtl >= 3.0 && nedtl <= 3.9) { nedtlGroup = "3.0-3.9" }
                // TODO
                if (nedtl < 3.0 || nedtl > 6.9) {
                    goodToGo = false
                    score2Element.value = ''
                    score2Element.setAttribute('placeholder', 'Netinkamas neDTL')
                }

                if (goodToGo === true) {
                    let score2Value = score2Data[sex][smokingStatus][ageGroup][aksGroup][nedtlGroup]
                    if (!isNaN(score2Value)) {
                        score2Element.value = score2Value
                    }
                }

            } else {
                score2Element.value = ''
            }
        }

        function riskGroupCalculate() {
            let score2Value = document.getElementById('score2').value
            if (score2Value) {
                let age = document.getElementById('age').value
                if (age < 50) {
                    if (score2Value < 2.5) {
                        document.getElementById('cvd-risk-low-medium').checked = true
                    } else if (score2Value >= 2.5 && score2Value <= 7.5) {
                        document.getElementById('cvd-risk-high').checked = true
                    } else if (score2Value > 7.5) {
                        document.getElementById('cvd-risk-very-high').checked = true
                    }
                } else if (age >= 50) {
                    if (score2Value < 5) {
                        document.getElementById('cvd-risk-low-medium').checked = true
                    } else if (score2Value >= 5 && score2Value < 10) {
                        document.getElementById('cvd-risk-high').checked = true
                    } else if (score2Value >= 10) {
                        document.getElementById('cvd-risk-very-high').checked = true
                    }
                }
            } else {
                document.getElementById('cvd-risk-low-medium').checked = false
                document.getElementById('cvd-risk-high').checked = false
                document.getElementById('cvd-risk-very-high').checked = false
            }


        }

